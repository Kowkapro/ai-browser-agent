# AI Browser Agent Configuration
# Copy this file to .env and fill in your API key

# === LLM Provider (at least one required) ===
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# === Model (optional) ===
# OpenAI: gpt-4o, gpt-4o-mini
# Anthropic: claude-sonnet-4-20250514
# LLM_MODEL=gpt-4o

# === Agent settings (optional) ===
# MAX_ITERATIONS=50
