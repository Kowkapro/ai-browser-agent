# AI Browser Agent Configuration
# Copy this file to .env and fill in your API key

# === Option 1: Universal (polza.ai, OpenRouter, any OpenAI-compatible proxy) ===
LLM_API_KEY=
LLM_BASE_URL=https://api.polza.ai/v1
LLM_MODEL=google/gemini-3-flash-preview

# === Option 2: Direct provider keys ===
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=gpt-4.1

# === Agent settings (optional) ===
# MAX_ITERATIONS=100
# WORKER_MAX_STEPS=30